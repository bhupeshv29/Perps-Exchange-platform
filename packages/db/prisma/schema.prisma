// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderSide {
  BID
  ASK
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
}

enum PositionSide {
  LONG
  SHORT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  balance   Balance?
  orders    Order[]
}

model Balance {
  userId    String   @id
  available Int      @default(0)
  locked    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id         String      @id
  userId     String
  marketId   String
  side       OrderSide
  type       OrderType
  status     OrderStatus @default(OPEN)
  price      Int?
  qty        Int
  filledQty  Int         @default(0)
  margin     Int
  leverage   Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  makerFills Fill[]      @relation("MakerOrder")
  takerFills Fill[]      @relation("TakerOrder")

  @@index([userId])
  @@index([marketId])
  @@index([marketId, status])
  @@index([userId, status])
}

model Fill {
  id           String   @id
  marketId     String
  makerOrderId String
  takerOrderId String
  makerUserId  String
  takerUserId  String
  price        Int
  qty          Int
  createdAt    DateTime @default(now())
  makerOrder   Order    @relation("MakerOrder", fields: [makerOrderId], references: [id], onDelete: Cascade)
  takerOrder   Order    @relation("TakerOrder", fields: [takerOrderId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([makerUserId])
  @@index([takerUserId])
  @@index([makerOrderId])
  @@index([takerOrderId])
}

model ClosedPosition {
  id          String       @id @default(uuid())
  userId      String
  marketId    String
  side        PositionSide
  qty         Int
  entryPrice  Int
  exitPrice   Int
  margin      Int
  leverage    Int
  realizedPnl Int
  openedAt    DateTime
  closedAt    DateTime     @default(now())

  @@index([userId])
  @@index([marketId])
}
