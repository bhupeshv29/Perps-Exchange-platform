// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
}

enum PositionSide {
  LONG
  SHORT
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balance Balance?

  orders    Order[]
  positions Position[]
}

model Balance {
  userId    String  @id
  available Decimal @default(0)
  locked    Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Market {
  id       String  @id @default(uuid())
  symbol   String  @unique
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  fills     Fill[]
  positions Position[]
}

model Order {
  id        String      @id
  userId    String
  marketId  String
  side      OrderSide
  type      OrderType
  status    OrderStatus @default(OPEN)
  price     Decimal?
  qty       Decimal
  filledQty Decimal     @default(0)
  margin    Decimal
  leverage  Decimal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market     Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  makerFills Fill[] @relation("MakerOrder")
  takerFills Fill[] @relation("TakerOrder")

  @@index([userId])
  @@index([marketId])
  @@index([marketId, status])
  @@index([userId, status])
}

model Fill {
  id           String  @id
  marketId     String
  makerOrderId String
  takerOrderId String
  makerUserId  String
  takerUserId  String
  price        Decimal
  qty          Decimal

  createdAt DateTime @default(now())

  market     Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  makerOrder Order  @relation("MakerOrder", fields: [makerOrderId], references: [id], onDelete: Cascade)
  takerOrder Order  @relation("TakerOrder", fields: [takerOrderId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([makerUserId])
  @@index([takerUserId])
  @@index([makerOrderId])
  @@index([takerOrderId])
}

model Position {
  id          String       @id @default(uuid())
  userId      String
  marketId    String
  side        PositionSide
  qty         Decimal
  entryPrice  Decimal
  margin      Decimal
  leverage    Decimal
  realizedPnl Decimal      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId, side])
  @@index([userId])
  @@index([marketId])
}

model ClosedPosition {
  id          String       @id @default(uuid())
  userId      String
  marketId    String
  side        PositionSide
  qty         Decimal
  entryPrice  Decimal
  exitPrice   Decimal
  margin      Decimal
  leverage    Decimal
  realizedPnl Decimal
  openedAt    DateTime
  closedAt    DateTime     @default(now())

  @@index([userId])
  @@index([marketId])
}
