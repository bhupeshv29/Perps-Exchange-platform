{
  "$schema": "https://turborepo.dev/schema.json",
   "globalEnv": [
   "PORT",
   "DATABASE_URL",
   "JWT_SECRET",
   "REDIS_URL",
   "FRONTEND_URL"
  ],
   "globalDependencies": [
    ".env"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
