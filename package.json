{
  "name": "perps-exchange-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "bun --filter @repo/db db:generate",
    "db:migrate": "bun --filter @repo/db db:migrate",
    "dev:backend": "bun --filter backend dev",
    "dev:engine": "bun --filter engine dev",
    "dev:db-worker": "bun --filter dbworker dev",
    "dev:ws": "bun --filter wsgateway dev",
    "dev:price-worker": "bun --filter priceworker dev"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "PerpsExchangePlatform": "."
  }
}
